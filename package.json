{
  "name": "estrutural",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:next": "next build",
    "build:staging": "node scripts/deploy-staging.mjs --build-only",
    "smoke:homepage": "node scripts/smoke-public-homepage.mjs",
    "preview": "firebase emulators:start --only hosting",
    "baseline:capture": "node scripts/capture-baseline.mjs",
