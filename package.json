    "audit:platform-data": "node scripts/audit-platform-data.mjs",
    "deploy": "npm run deploy:prod",
    "deploy:prod": "npm run build && npx firebase-tools deploy --project hocapp-44760 --only hosting,firestore:rules,firestore:indexes,storage",
    "deploy:staging": "node scripts/deploy-staging.mjs",
    "start": "firebase emulators:start --only hosting",
    "lint": "eslint .",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/material-symbols-outlined": "^5.2.43",
    "autoprefixer": "^10.5.0",
