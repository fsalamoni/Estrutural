    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "firebase-tools": "^14.22.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
