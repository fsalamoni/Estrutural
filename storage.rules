rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /platform-icons/{allPaths=**} {
      // Ícones são públicos (necessário para exibir nas plataformas)
      allow read: if true;

      // Somente o admin pode enviar e excluir ícones
      allow write: if request.auth != null
                   && request.auth.uid == "ADMIN_UID_PLACEHOLDER";
    }
  }
}
