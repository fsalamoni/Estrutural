rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == "fsalamoni@gmail.com";
    }

    match /platforms/{platformId} {
      // Qualquer visitante pode ler plataformas visíveis
      // O admin pode ler todas (incluindo ocultas)
      allow read: if resource.data.visible == true || isAdmin();

      // Somente o admin pode criar, editar e excluir
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      // Categorias são públicas (necessárias para agrupar plataformas no portal)
      allow read: if true;

      // Somente o admin pode criar, editar e excluir
      allow write: if request.auth != null
                   && request.auth.uid == "ADMIN_UID_PLACEHOLDER";
    }
  }
}
