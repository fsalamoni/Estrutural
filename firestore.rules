rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email is string
             && request.auth.token.email == "fsalamoni@gmail.com";
    }

    function isHttpsUrl(value) {
      return value is string
             && value.size() <= 2048
             && value.matches('^https://[^\\s]+$');
    }

    function isAllowedCategory(value) {
      return value == 'Trabalho'
             || value == 'IA'
             || value == 'RPG'
             || value == 'Jogos'
             || value == 'Outros';
    }

    function isAllowedAuthMethod(value) {
      return value == 'email'
             || value == 'google'
             || value == 'ambos'
             || value == 'nenhum';
    }

    function hasPlatformShape(data) {
      return data.keys().hasAll([
               'name',
               'description',
               'category',
               'accessUrl',
               'iconUrl',
               'authMethod',
               'visible',
               'order',
               'createdAt',
               'updatedAt'
             ])
             && data.keys().hasOnly([
               'name',
               'description',
               'category',
               'accessUrl',
               'iconUrl',
               'authMethod',
               'visible',
               'order',
               'createdAt',
               'updatedAt'
             ]);
    }

    function isValidPlatform(data) {
      return hasPlatformShape(data)
             && data.name is string
             && data.name.size() > 0
             && data.name.size() <= 120
             && data.description is string
             && data.description.size() <= 1000
             && data.category is string
             && isAllowedCategory(data.category)
             && isHttpsUrl(data.accessUrl)
             && data.iconUrl is string
             && (data.iconUrl == '' || isHttpsUrl(data.iconUrl))
             && isAllowedAuthMethod(data.authMethod)
             && data.visible is bool
             && data.order is int
             && data.order >= 0
             && data.createdAt is timestamp
             && data.updatedAt is timestamp;
    }

    function isValidCreate() {
      return isValidPlatform(request.resource.data)
             && request.resource.data.createdAt == request.time
             && request.resource.data.updatedAt == request.time;
    }

    function isValidUpdate() {
      return isValidPlatform(request.resource.data)
             && request.resource.data.createdAt == resource.data.createdAt
             && request.resource.data.updatedAt == request.time;
    }

    match /platforms/{platformId} {
      // Qualquer visitante pode ler plataformas visíveis
      // O admin pode ler todas (incluindo ocultas)
      allow read: if resource.data.visible == true || isAdmin();

      allow create: if isAdmin() && isValidCreate();
      allow update: if isAdmin() && isValidUpdate();
      allow delete: if isAdmin();
    }
  }
}
